# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Amazon Product Advertising API
# ===========================================
AMAZON_ACCESS_KEY=your-access-key
AMAZON_SECRET_KEY=your-secret-key

# Partner Tags (各国別)
AMAZON_PARTNER_TAG_JP=your-jp-tag-22
AMAZON_PARTNER_TAG_US=your-us-tag-20
AMAZON_PARTNER_TAG_UK=your-uk-tag-21
AMAZON_PARTNER_TAG_DE=your-de-tag-21
AMAZON_PARTNER_TAG_FR=your-fr-tag-21
AMAZON_PARTNER_TAG_AU=your-au-tag-22
AMAZON_PARTNER_TAG_CA=your-ca-tag-20

# ===========================================
# 楽天アフィリエイト (日本のみ)
# ===========================================
RAKUTEN_APPLICATION_ID=your-application-id
RAKUTEN_AFFILIATE_ID=your-affiliate-id

# ===========================================
# ASP (もしもアフィリエイト等)
# ===========================================
MOSHIMO_AFFILIATE_ID=your-moshimo-id
VALUECOMMERCE_SID=your-valuecommerce-sid
A8_AFFILIATE_ID=your-a8-id

# ===========================================
# CJ Affiliate (海外向け)
# ===========================================
CJ_WEBSITE_ID=your-cj-website-id
CJ_AFFILIATE_ID=your-cj-affiliate-id

# ===========================================
# Awin (海外向け)
# ===========================================
AWIN_AFFILIATE_ID=your-awin-affiliate-id
