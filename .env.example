# ===========================================
# アプリケーション設定
# ===========================================
NEXT_PUBLIC_SITE_URL=https://sized-furniture.com
NODE_ENV=development

# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Amazon Product Advertising API
# ===========================================
AMAZON_ACCESS_KEY=your-access-key
AMAZON_SECRET_KEY=your-secret-key

# Partner Tags (各国別)
AMAZON_PARTNER_TAG_JP=your-jp-tag-22
AMAZON_PARTNER_TAG_US=your-us-tag-20
AMAZON_PARTNER_TAG_UK=your-uk-tag-21
AMAZON_PARTNER_TAG_DE=your-de-tag-21
AMAZON_PARTNER_TAG_FR=your-fr-tag-21
AMAZON_PARTNER_TAG_AU=your-au-tag-22
AMAZON_PARTNER_TAG_CA=your-ca-tag-20

# ===========================================
# 楽天アフィリエイト (日本のみ)
# ===========================================
RAKUTEN_APPLICATION_ID=your-application-id
RAKUTEN_AFFILIATE_ID=your-affiliate-id

# ===========================================
# ASP (もしもアフィリエイト等)
# ===========================================
MOSHIMO_AFFILIATE_ID=your-moshimo-id
VALUECOMMERCE_SID=your-valuecommerce-sid
A8_AFFILIATE_ID=your-a8-id

# ===========================================
# CJ Affiliate (海外向け)
# ===========================================
CJ_WEBSITE_ID=your-cj-website-id
CJ_AFFILIATE_ID=your-cj-affiliate-id

# ===========================================
# Awin (海外向け)
# ===========================================
AWIN_AFFILIATE_ID=your-awin-affiliate-id

# ===========================================
# Cron Job 認証
# ===========================================
CRON_SECRET=your-secure-cron-secret-key

# ===========================================
# Google Analytics
# ===========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# Sentry エラー監視
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=sized-furniture

# ===========================================
# Vercel (自動設定される環境変数)
# ===========================================
# VERCEL_URL - デプロイURL
# VERCEL_ENV - 環境 (production/preview/development)
# VERCEL_GIT_COMMIT_SHA - コミットSHA
